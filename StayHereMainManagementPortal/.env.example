# Copy to .env.local. Used for `npm run build` defaults when no localStorage override exists.
# `npm run dev` uses same-origin /stayhere-api/* (Vite proxy); these URLs apply mainly to production builds.
# Adjust ports if yours differ (see scripts/README.md).
VITE_PROPERTY_OWNER_API=http://localhost:7103/api
VITE_PROPERTY_API=http://localhost:7101/api
VITE_CUSTOMER_API=http://localhost:7102/api
VITE_STATIC_API=http://localhost:7104/api
