    {
      "name": "AuthService",
      "description": "Identity: signup, OTP login, profiles, post-login onboarding.",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl_AuthService}}/auth/signup",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"phoneNumber\": \"+254700000000\",\n  \"fullName\": \"Test User\",\n  \"userType\": \"Individual\"\n}"
            }
          }
        },
        {
          "name": "Login (request OTP email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl_AuthService}}/auth/login",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "Login (request OTP SMS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl_AuthService}}/auth/login",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+254700000000\"\n}"
            }
          }
        },
        {
          "name": "Login (Entra token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl_AuthService}}/auth/login",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entraToken\": \"<azure-ad-access-token>\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl_AuthService}}/auth/verifyotp",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target\": \"user@example.com\",\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get profiles for user",
          "request": {
            "method": "GET",
            "header": [],
